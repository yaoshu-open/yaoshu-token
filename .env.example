# ============================================================
# Yaoshu Token — Environment Variable Configuration
# ============================================================
# Copy to .env and fill in before deployment.
# Docker Compose loads .env automatically.
# ============================================================

# ---- Server ----
SERVER_PORT=9527
SPRING_PROFILES_ACTIVE=prod

# ---- Database (MySQL) ----
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/yaoshu_token?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your-password-here

# ---- Redis ----
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=your-password-here

# ---- Security (Multi-node Deployment Required) ----
# SESSION_SECRET=random-string-change-me
# CRYPTO_SECRET=random-string-change-me

# ---- Timezone ----
TZ=Asia/Shanghai

# ---- Optional ----
# STREAMING_TIMEOUT=300  # Streaming timeout in seconds
# MAX_REQUEST_BODY_MB=32  # Max request body size in MB
# AZURE_DEFAULT_API_VERSION=2025-04-01-preview
